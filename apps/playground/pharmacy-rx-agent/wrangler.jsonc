{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "pharmacy-rx-agent",
  "main": "src/index.ts",
  "compatibility_date": "2026-04-01",
  "compatibility_flags": ["nodejs_compat"],
  "assets": {
    "directory": "./public"
  },
  "durable_objects": {
    "bindings": [
      {
        "name": "PharmacyAgent",
        "class_name": "PharmacyAgent"
      },
      {
        "name": "PharmacyWa",
        "class_name": "PharmacyWaAgent"
      },
      {
        "name": "ConversationRegistry",
        "class_name": "ConversationRegistry"
      }
    ]
  },
  "migrations": [
    {
      "tag": "v1",
      "new_sqlite_classes": ["PharmacyAgent"]
    },
    {
      "tag": "v2",
      "new_sqlite_classes": ["PharmacyWaAgent"]
    },
    {
      "tag": "v3",
      "new_sqlite_classes": ["ConversationRegistry"]
    }
  ],
  "observability": {
    "enabled": true
  },
  "vars": {
    "PUBLIC_URL": "https://pharmacy-rx-agent.mithushancj.workers.dev",
    "COMMERCE_API_URL": "https://checkoutpay.mithushancj.com"
  }
  // Secrets (set with `wrangler secret put <NAME>`):
  //   OPENAI_API_KEY
  //   WHATSAPP_ACCESS_TOKEN  WHATSAPP_APP_SECRET
  //   WHATSAPP_PHONE_NUMBER_ID  WHATSAPP_VERIFY_TOKEN
  //   AGENT_CALLBACK_SECRET  (shared with commerce backend)
  //   ADMIN_TOKEN            (dashboard inbox read token)
}

{
  "name": "agent-starter-node",
  "license": "Apache-2.0",
  "version": "1.0.11",
  "private": true,
  "type": "module",
  "scripts": {
    "prepare:plugin": "bun run --cwd ../../../../packages/livekit-plugin build",
    "prepare": "bun run prepare:plugin",
    "build": "bun run prepare && vite build",
    "clean": "rm -rf dist",
    "typecheck": "bun run prepare && tsc --noEmit",
    "lint": "eslint \"**/*.{ts,js}\"",
    "lint:fix": "eslint --fix \"**/*.{ts,js}\"",
    "format": "prettier --write \"**/*.{ts,js,json,md}\"",
    "format:check": "prettier --check \"**/*.{ts,js,json,md}\"",
    "test": "vitest --run",
    "test:watch": "vitest",
    "dev:setup": "bun run build",
    "dev": "node dist/main.js dev",
    "dev:rebuild": "bun run dev:setup && node dist/main.js dev",
    "download-files": "node dist/main.js download-files",
    "start": "bun run prepare && node dist/main.js start"
  },
  "engines": {
    "node": ">=22.0.0",
    "bun": ">=1.3.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.3",
    "@trivago/prettier-plugin-sort-imports": "^5.2.2",
    "@types/node": "^22.19.11",
    "eslint": "^9.39.3",
    "globals": "^16.5.0",
    "jiti": "^2.6.1",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.56.0",
    "vite": "^7.3.1",
    "vitest": "^4.0.18"
  },
  "dependencies": {
    "@ai-sdk/openai": "^3.0.41",
    "@kuralle-agents/core": "workspace:*",
    "@kuralle-agents/livekit-plugin": "workspace:*",
    "@livekit/agents": "^1.0.46",
    "@livekit/agents-plugin-livekit": "^1.0.46",
    "@livekit/agents-plugin-silero": "^1.0.46",
    "@livekit/noise-cancellation-node": "^0.1.9",
    "ai": "^6.0.116",
    "dotenv": "^17.3.1",
    "zod": "^4.0.0"
  }
}

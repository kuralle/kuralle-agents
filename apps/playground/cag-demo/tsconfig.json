{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "lib": ["ES2022"],
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,
    "baseUrl": ".",
    "paths": {
      "@kuralle-agents/core": ["../../../packages/core/src/index.ts"],
      "@kuralle-agents/hono-server": ["../../../packages/hono-server/src/index.ts"],
      "@kuralle-agents/rag": ["../../../packages/rag/src/index.ts"],
      "@kuralle-agents/tools": ["../../../packages/tools/src/index.ts"]
    }
  },
  "include": ["*.ts", "../_shared/runtime/**/*.ts"]
}

{
  "name": "@kuralle-agents/core",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/kuralle/kuralle-agents.git",
    "directory": "packages/kuralle-core"
  },
  "version": "0.5.0",
  "description": "A framework for structured conversational AI agents",
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist",
    "guides",
    "README.md"
  ],
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./flows": {
      "types": "./dist/flows/index.d.ts",
      "default": "./dist/flows/index.js"
    },
    "./runtime": {
      "types": "./dist/runtime/index.d.ts",
      "default": "./dist/runtime/index.js"
    },
    "./hooks": {
      "types": "./dist/hooks/index.d.ts",
      "default": "./dist/hooks/index.js"
    },
    "./guards": {
      "types": "./dist/guards/index.d.ts",
      "default": "./dist/guards/index.js"
    },
    "./session": {
      "types": "./dist/session/index.d.ts",
      "default": "./dist/session/index.js"
    },
    "./session/testing": {
      "types": "./dist/session/testing.d.ts",
      "default": "./dist/session/testing.js"
    },
    "./testing": {
      "types": "./dist/testing/index.d.ts",
      "default": "./dist/testing/index.js"
    },
    "./tools": {
      "types": "./dist/tools/index.d.ts",
      "default": "./dist/tools/index.js"
    },
    "./prompts": {
      "types": "./dist/prompts/index.d.ts",
      "default": "./dist/prompts/index.js"
    },
    "./persona": {
      "types": "./dist/persona/index.d.ts",
      "default": "./dist/persona/index.js"
    },
    "./types": {
      "types": "./dist/types/index.d.ts",
      "default": "./dist/types/index.js"
    },
    "./memory": {
      "types": "./dist/memory/index.d.ts",
      "default": "./dist/memory/index.js"
    },
    "./foundation": {
      "types": "./dist/foundation/index.d.ts",
      "default": "./dist/foundation/index.js"
    },
    "./capabilities": {
      "types": "./dist/capabilities/index.d.ts",
      "default": "./dist/capabilities/index.js"
    },
    "./realtime": {
      "types": "./dist/realtime/index.d.ts",
      "default": "./dist/realtime/index.js"
    }
  },
  "peerDependencies": {
    "ai": "^6.0.0",
    "zod": "^3.0.0"
  },
  "devDependencies": {
    "@cloudflare/vitest-pool-workers": "^0.12.7",
    "@kuralle-agents/realtime-audio": "workspace:*",
    "@ai-sdk/openai": "^3.0.0",
    "@types/node": "^20.11.0",
    "ai": "^6.0.0",
    "bun-types": "^1.3.0",
    "dotenv": "^16.4.0",
    "typescript": "^5.3.0",
    "vitest": "^3.2.4",
    "zod": "^3.23.0"
  },
  "scripts": {
    "prebuild": "rm -rf dist",
    "build": "tsc -p tsconfig.json",
    "typecheck:examples": "tsc --noEmit -p tsconfig.examples.json",
    "clean": "rm -rf dist",
    "prepublishOnly": "npm run clean && npm run build",
    "test": "bun test ./test && vitest run --config vitest.config.ts",
    "test:journal-key-workers": "vitest run --config vitest.config.ts",
    "test:workspace-autoregister": "bun test ./test/core-workspace/workspace-autoregister.test.ts",
    "smoke:textdriver": "bun test ./test/core-channel/textdriver.smoke.ts",
    "smoke:flow": "bun test ./test/core-flow/flow.smoke.ts",
    "smoke:agent": "bun test ./test/core-agent/agent.smoke.ts",
    "smoke:approval": "bun test ./test/core-policy/approval.smoke.ts",
    "smoke:knowledge": "bun test ./test/core-grounding/knowledge.smoke.ts",
    "smoke:realtime": "bun test ./test/core-voice/realtime.smoke.ts"
  },
  "dependencies": {
    "chrono-node": "^2.6.0",
    "zod-to-json-schema": "^3.24.0"
  }
}

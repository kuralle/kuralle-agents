{
  "name": "@kuralle-agents/redis-store",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/kuralle/kuralle-agents.git",
    "directory": "packages/kuralle-redis-store"
  },
  "version": "0.3.12",
  "description": "Redis-backed SessionStore for Kuralle (supports Upstash and common Redis clients)",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "dependencies": {
    "@kuralle-agents/core": "workspace:*"
  },
  "peerDependencies": {
    "@kuralle-agents/core": "workspace:*",
    "@kuralle-agents/rag": "workspace:*"
  },
  "devDependencies": {
    "@ai-sdk/openai": "^3.0.0",
    "@kuralle-agents/rag": "workspace:*",
    "@types/node": "^20.11.0",
    "ai": "^6.0.0",
    "dotenv": "^16.4.0",
    "redis": "^4.7.0",
    "tsx": "^4.7.0",
    "typescript": "^5.3.0",
    "zod": "^3.22.0"
  },
  "scripts": {
    "prebuild": "rm -rf dist",
    "build": "tsc -p tsconfig.json",
    "test": "bun test ./test ./src/__tests__",
    "dev:local": "tsx examples/local-redis/test.ts",
    "dev:multi": "tsx examples/local-redis/multi-turn.ts",
    "clean": "rm -rf dist",
    "prepublishOnly": "npm run build"
  },
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist",
    "README.md"
  ]
}

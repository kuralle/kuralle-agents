{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "cf-voice-realtime-gemini-flow",
  "main": "src/server.ts",
  "compatibility_date": "2026-04-01",
  "compatibility_flags": ["nodejs_compat"],
  "assets": {
    "directory": "./dist/client",
    "binding": "ASSETS",
    "not_found_handling": "single-page-application"
  },
  "durable_objects": {
    "bindings": [
      {
        "name": "CfVoiceRealtimeFlowAgent",
        "class_name": "CfVoiceRealtimeFlowAgent"
      }
    ]
  },
  "migrations": [
    {
      "tag": "v1",
      "new_sqlite_classes": ["CfVoiceRealtimeFlowAgent"]
    }
  ],
  "ai": {
    "binding": "AI"
  },
  "observability": {
    "enabled": true
  }
  // GEMINI_API_KEY is a secret — set with:
  //   wrangler secret put GEMINI_API_KEY
}

{
  "name": "@kuralle-agents/transport-base",
  "version": "0.8.5",
  "description": "Shared primitives for Kuralle voice transport adapters (TransportAdapterBase, CallbackTextOutput, ResamplingAudioInput/Output, G.711 codec, contract test harness).",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./codec/g711": {
      "types": "./dist/codec/g711.d.ts",
      "import": "./dist/codec/g711.js"
    },
    "./testing": {
      "types": "./dist/testing.d.ts",
      "import": "./dist/testing.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "prebuild": "rm -rf dist",
    "build": "tsc",
    "clean": "rm -rf dist",
    "typecheck": "tsc --noEmit",
    "test": "bun test test"
  },
  "peerDependencies": {
    "@kuralle-agents/livekit-plugin": "workspace:*",
    "@livekit/agents": ">=1.0.0",
    "@livekit/rtc-node": ">=0.12.0"
  },
  "dependencies": {
    "alawmulaw": "^6.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "typescript": "^5.5.0"
  },
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/kuralle/kuralle-agents.git",
    "directory": "packages/kuralle-transport-base"
  }
}

{
  "name": "@kuralle-agents/analytics-sdk",
  "version": "0.2.1",
  "type": "module",
  "description": "Type-safe SDK for sending analytics events to Kuralle Analytics Platform",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./react": {
      "types": "./dist/react.d.ts",
      "default": "./dist/react.js"
    }
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "scripts": {
    "prebuild": "rm -rf dist",
    "build": "tsc -p tsconfig.json",
    "dev": "tsc -w -p tsconfig.json",
    "test": "bun test test"
  },
  "files": [
    "dist"
  ],
  "keywords": [
    "kuralle",
    "analytics",
    "sdk",
    "telemetry"
  ],
  "license": "MIT",
  "dependencies": {
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@types/react": "^19.0.0",
    "react": "^19.0.0"
  },
  "peerDependencies": {
    "react": ">=18.0.0"
  },
  "peerDependenciesMeta": {
    "react": {
      "optional": true
    }
  }
}

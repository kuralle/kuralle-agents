{
  "name": "@kuralle-agents/analytics-sdk",
  "version": "0.2.0",
  "type": "module",
  "description": "Type-safe SDK for sending analytics events to Kuralle Analytics Platform",
  "exports": {
    ".": "./src/index.ts",
    "./react": "./src/react.ts"
  },
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "scripts": {
    "prebuild": "rm -rf dist",
    "build": "~/.bun/bin/bun build ./src/index.ts ./src/react.ts --outdir ./dist --target bun --minify --sourcemap --external react",
    "dev": "~/.bun/bin/bun build ./src/index.ts ./src/react.ts --outdir ./dist --target bun --watch --external react",
    "test": "bun test test"
  },
  "files": [
    "src",
    "dist"
  ],
  "keywords": [
    "kuralle",
    "analytics",
    "sdk",
    "telemetry"
  ],
  "license": "MIT",
  "dependencies": {
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@types/react": "^19.0.0",
    "react": "^19.0.0"
  },
  "peerDependencies": {
    "react": ">=18.0.0"
  },
  "peerDependenciesMeta": {
    "react": {
      "optional": true
    }
  }
}

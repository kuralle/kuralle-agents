{
  "name": "@kuralle-agents/hono-server",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/kuralle/kuralle-agents.git",
    "directory": "packages/kuralle-hono-server"
  },
  "version": "0.3.18",
  "description": "Hono router for hosting Kuralle createRuntime() over HTTP, SSE, and WebSocket",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "dependencies": {
    "ai": "^6.0.0",
    "hono": "^4.0.0",
    "@kuralle-agents/core": "workspace:*"
  },
  "peerDependencies": {
    "@kuralle-agents/core": "workspace:*"
  },
  "devDependencies": {
    "@ai-sdk/openai": "^3.0.0",
    "@hono/node-server": "^1.13.0",
    "@hono/node-ws": "^1.0.0",
    "@types/bun": "^1.3.6",
    "@types/node": "^20.11.0",
    "dotenv": "^16.4.0",
    "openai": "^4.104.0",
    "tsx": "^4.7.0",
    "zod": "^3.22.0",
    "typescript": "^5.3.0"
  },
  "scripts": {
    "prebuild": "rm -rf dist",
    "build": "tsc -p tsconfig.json",
    "test": "bun test ./test",
    "test:contracts": "npm run build && node --test test/widget-welcome.contract.test.mjs",
    "smoke:sse": "bun test ./test/sse.smoke.ts",
    "smoke:openai-compat": "bun test ./test/openai-compat.live.ts",
    "test:openai-compat": "bun test ./test/openai-compat*.test.ts",
    "dev": "tsx examples/basic-server/server.ts",
    "dev:bun": "bun examples/bun-server/server.ts",
    "clean": "rm -rf dist",
    "prepublishOnly": "npm run build"
  },
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist",
    "README.md"
  ]
}

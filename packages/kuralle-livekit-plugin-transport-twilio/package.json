{
  "name": "@kuralle-agents/livekit-plugin-transport-twilio",
  "version": "0.7.0",
  "description": "Twilio Media Streams transport adapter for Kuralle agents. Works with Node.js, Bun, Deno, and any WebSocket-compatible runtime.",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "prebuild": "rm -rf dist",
    "build": "tsc",
    "clean": "rm -rf dist",
    "typecheck": "tsc --noEmit",
    "example:echo": "tsx examples/echo_bot.ts",
    "example:server": "tsx examples/standalone_server.ts",
    "example:hono": "tsx examples/hono_server.ts"
  },
  "dependencies": {},
  "peerDependencies": {
    "@kuralle-agents/livekit-plugin": "workspace:*",
    "@kuralle-agents/transport-base": "workspace:*",
    "@livekit/agents": ">=1.0.0"
  },
  "devDependencies": {
    "hono": "^4.6.0",
    "tsx": "^4.19.0",
    "typescript": "^5.5.0",
    "ws": "^8.18.0"
  },
  "keywords": [
    "kuralle",
    "livekit",
    "twilio",
    "voice",
    "transport"
  ],
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/kuralle/kuralle-agents.git",
    "directory": "packages/kuralle-livekit-plugin-transport-twilio"
  }
}

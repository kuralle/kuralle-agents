{
  "name": "@kuralle-agents/skills",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/kuralle/kuralle-agents.git",
    "directory": "packages/kuralle-skills"
  },
  "version": "0.7.2",
  "description": "Anthropic-style Agent Skills with progressive disclosure for Kuralle",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "dependencies": {
    "@kuralle-agents/core": "workspace:*"
  },
  "peerDependencies": {
    "zod": "^4.0.0"
  },
  "devDependencies": {
    "@cloudflare/vitest-pool-workers": "^0.12.7",
    "@kuralle-agents/fs": "workspace:*",
    "@types/node": "^20.11.0",
    "bun-types": "^1.3.0",
    "typescript": "^5.3.0",
    "vitest": "^3.2.4",
    "zod": "^4.0.0"
  },
  "scripts": {
    "prebuild": "rm -rf dist",
    "build": "tsc -p tsconfig.json",
    "clean": "rm -rf dist",
    "test": "bun test test/parse.test.ts test/stores.test.ts test/fs-store.test.ts test/capability.test.ts test/agent.test.ts && vitest run --config vitest.config.ts",
    "test:skill-parse": "bun test test/parse.test.ts",
    "test:skill-stores": "bun test test/stores.test.ts",
    "test:skill-fsstore": "bun test test/fs-store.test.ts",
    "test:skill-capability": "bun test test/capability.test.ts",
    "test:skill-agent": "bun test test/agent.test.ts",
    "test:skill-workers": "vitest run --config vitest.config.ts",
    "prepublishOnly": "npm run build"
  },
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist",
    "README.md"
  ]
}

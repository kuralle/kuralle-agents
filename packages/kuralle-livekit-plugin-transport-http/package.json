{
  "name": "@kuralle-agents/livekit-plugin-transport-http",
  "version": "0.3.18",
  "description": "HTTP/SSE transport adapter for LiveKit Agents. Run text chatbots and voice agents over standard HTTP with Server-Sent Events.",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./hono": {
      "types": "./dist/integrations/hono.d.ts",
      "import": "./dist/integrations/hono.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "prebuild": "rm -rf dist",
    "build": "tsc",
    "clean": "rm -rf dist"
  },
  "dependencies": {},
  "peerDependencies": {
    "@kuralle-agents/livekit-plugin": "workspace:*",
    "@kuralle-agents/transport-base": "workspace:*",
    "@livekit/agents": ">=1.0.0"
  },
  "peerDependenciesMeta": {
    "hono": {
      "optional": true
    }
  },
  "devDependencies": {
    "@hono/node-server": "^1.19.11",
    "typescript": "^5.5.0",
    "hono": "^4.0.0"
  },
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/kuralle/kuralle-agents.git",
    "directory": "packages/kuralle-livekit-plugin-transport-http"
  }
}

{
  "name": "@kuralle-agents/wavekat-vad-node",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "description": "Node.js bindings for wavekat-vad — Rust-native VAD (WebRTC + TEN-VAD) via napi-rs",
  "main": "index.js",
  "types": "index.d.ts",
  "napi": {
    "binaryName": "kuralle-wavekat-vad-node",
    "targets": [
      "x86_64-apple-darwin",
      "aarch64-apple-darwin",
      "x86_64-unknown-linux-gnu",
      "aarch64-unknown-linux-gnu"
    ]
  },
  "scripts": {
    "build": "napi build --platform --release",
    "build:debug": "napi build --platform",
    "test": "bun test test"
  },
  "devDependencies": {
    "@napi-rs/cli": "^3.6.2"
  }
}
